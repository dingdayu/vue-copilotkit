{
  "name": "vue-copilotkit",
  "private": true,
  "description": "Vue 3 CopilotKit monorepo with unified package and demo app.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dingdayu/vue-copilotkit.git"
  },
  "homepage": "https://github.com/dingdayu/vue-copilotkit#readme",
  "bugs": {
    "url": "https://github.com/dingdayu/vue-copilotkit/issues"
  },
  "keywords": [
    "vue",
    "copilotkit",
    "ai",
    "assistant",
    "monorepo"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "examples",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "clean": "turbo clean",
    "format": "turbo format",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "publish:packages": "turbo build && changeset publish"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.13.10",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.1",
    "prettier": "^3.5.3",
    "turbo": "^2.8.14",
    "typescript": "^5.8.2"
  },
  "packageManager": "pnpm@10.5.2"
}
