{
  "name": "vue-copilotkit",
  "private": false,
  "workspaces": [
    "examples",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm run -F examples dev",
    "build": "turbo build",
    "clean": "lerna clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "publish:packages": "pnpm -r --filter @dingdayu/* publish --access public"
  },
  "dependencies": {
    "vue": "^3.4.31"
  },
  "devDependencies": {
    "@types/node": "^18.11.17",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "lerna": "^8.1.8",
    "prettier": "^3.2.5",
    "turbo": "^2.0.6",
    "typescript": "^5.2.3"
  },
  "packageManager": "pnpm@9.5.0"
}
