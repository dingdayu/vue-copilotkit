{
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "module": "ESNext",
    "target": "es6",
    "allowJs": false,
    "noUnusedLocals": false,
    "preserveConstEnums": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "inlineSources": true,
    "declaration": true,
    "experimentalDecorators": true,
    "downlevelIteration": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "resolveJsonModule": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable", "ScriptHost"],
    "paths": {
      "@dingdayu/vue-copilotkit-core": ["packages/vue-core/src/index.ts"],
      "@dingdayu/vue-copilotkit-ui": ["packages/vue-ui/src/index.ts"]
    }
  }
}
